{
  "name": "bud-studio-desktop",
  "productName": "Bud Studio",
  "version": "0.1.0",
  "description": "Bud Studio AI Assistant Desktop App",
  "author": "Bud",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "npm run build:main && npm run build:preload",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "fix-standalone-name": "node scripts/fix-standalone-name.js",
    "package": "npm run build && npm run fix-standalone-name && electron-builder",
    "package:mac": "npm run package -- --mac",
    "package:mac-dmg": "npm run package -- --mac",
    "package:mac-dir": "npm run package -- --mac --dir",
    "package:win": "npm run package -- --win",
    "package:linux": "npm run package -- --linux"
  },
  "dependencies": {
    "get-port": "^7.1.0",
    "next": "15.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
