{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Bud Studio",
  "version": "0.1.0",
  "identifier": "com.bud.studio",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Bud Studio Desktop App",
    "longDescription": "A desktop application for Bud Studio - your AI-powered development assistant.",
    "resources": {
      "../../web/.next/standalone": "web/.next/standalone"
    },
    "macOS": {
      "entitlements": null,
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
